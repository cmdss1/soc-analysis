API_HOST=0.0.0.0
API_PORT=8000

CORS_ORIGINS=http://localhost:3000

# Must match where workspace containers POST ingest events (no trailing slash).
PUBLIC_API_BASE=http://localhost:8000

# Homelab: use the same origin as in the browser (often HTTPS); see docs/KASM_ADMIN.md.
KASM_BASE_URL=https://your-kasm.example.com
KASM_API_KEY=
KASM_API_SECRET=
KASM_IMAGE_ID=
KASM_USER_ID=

# false if Developer API calls fail with SSL certificate errors (homelab HTTPS).
KASM_VERIFY_TLS=true

BLOCK_PRIVATE_TARGET_IPS=true

MOCK_KASM=false
MOCK_KASM_VIEWER_URL=
